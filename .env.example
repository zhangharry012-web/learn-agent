# Default configuration for learn-agent
# Copy this file to .env and fill in your values.

# Provider selection: anthropic | openai | deepseek | openai-compatible
LLM_PROVIDER=anthropic

# Generic config
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=

# Backward-compatible Anthropic aliases
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximum LLM tool interaction steps per command (default: 25)
# LLM_MAX_TOOL_STEPS=25
